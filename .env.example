# ──────────────────────────────────────────────
# Firebase Cloud Messaging (FCM)
# ──────────────────────────────────────────────
FCM_SA_PATH=/path/to/firebase-service-account.json
FCM_PROJECT_ID=your-firebase-project-id

# ──────────────────────────────────────────────
# Apple In-App Purchase (App Store)
# ──────────────────────────────────────────────
APPLE_IAP_SHARED_SECRET=your_apple_shared_secret_here
APPLE_BUNDLE_ID=com.classy.app

# ──────────────────────────────────────────────
# Google Play In-App Purchase
# ──────────────────────────────────────────────
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/google-service-account.json
ANDROID_PACKAGE_NAME=com.classy.app
